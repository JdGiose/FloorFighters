<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Floor Fighter | Battle System & Progress Tracker</title>
    <style>
        :root {
            --power-color: #ff4136;   /* Red */
            --style-color: #b10dc9;   /* Purple */
            --spin-color: #ffdc00;    /* Yellow */
            --footwork-color: #0074d9; /* Blue */
            --freeze-color: #2ecc40;   /* Green */
            --toprock-color: #ff851b;  /* Orange */
            --battle-color: #a0a0a0;   /* Grey */
            --character-color: #8b4513;/* Brown */
            --fusion-color: #8a2be2;   /* BlueViolet */
            --legacy-color: #ffd700;   /* Gold */
            --bg-dark: #0a0a0a;
            --card-bg: #151515;
            --text-light: #f4f4f4;
        }

        body {
            font-family: 'Segoe UI', Roboto, sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-light);
            margin: 0;
            padding: 20px;
        }

        header {
            text-align: center;
            margin-bottom: 30px;
            border-bottom: 2px solid var(--power-color);
            padding-bottom: 20px;
        }

        h1 { margin: 0; text-transform: uppercase; letter-spacing: 2px; }

        #exp-display {
            text-align: center;
            font-size: 1.8em;
            font-weight: bold;
            color: var(--spin-color);
            margin: 20px 0;
            text-shadow: 0 0 10px rgba(255, 220, 0, 0.3);
        }

        .container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            max-width: 1200px;
            margin: 0 auto;
        }

        @media (max-width: 800px) { .container { grid-template-columns: 1fr; } }

        /* Panels */
        .panel {
            background-color: var(--card-bg);
            padding: 25px;
            border-radius: 12px;
            border: 1px solid #333;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .scroll-area {
            max-height: 70vh;
            overflow-y: auto;
            padding-right: 10px;
        }

        /* Move Items */
        .move-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid #222;
        }

        .move-name-label { cursor: pointer; font-weight: 500; }
        .move-exp { color: #888; font-size: 0.9em; margin-left: 10px; font-family: monospace; }
        
        .move-checkbox {
            width: 22px;
            height: 22px;
            accent-color: var(--freeze-color);
            cursor: pointer;
        }

        /* Gym Cards */
        .gym-card {
            padding: 20px;
            border-radius: 8px;
            background-color: #222;
            margin-bottom: 15px;
            border-left: 6px solid #444;
            transition: 0.3s;
        }

        .gym-header { display: flex; justify-content: space-between; align-items: center; }
        .gym-name { font-weight: bold; font-size: 1.1em; text-transform: uppercase; }

        .gym-status {
            font-size: 0.8em;
            padding: 4px 10px;
            border-radius: 20px;
            font-weight: bold;
        }

        .status-locked { background: #444; color: #aaa; }
        .status-eligible { background: var(--freeze-color); color: #000; box-shadow: 0 0 10px var(--freeze-color); }

        /* Progress Bars */
        .progress-bar-container {
            height: 8px;
            background-color: #111;
            border-radius: 10px;
            margin-top: 15px;
            overflow: hidden;
        }

        .progress-bar { height: 100%; width: 0%; transition: width 0.5s ease; }

        /* Individual Gym Colors */
        .gym-card[data-color="power"] { border-color: var(--power-color); }
        .gym-card[data-color="power"] .progress-bar { background-color: var(--power-color); }
        .gym-card[data-color="style"] { border-color: var(--style-color); }
        .gym-card[data-color="style"] .progress-bar { background-color: var(--style-color); }
        .gym-card[data-color="spin"] { border-color: var(--spin-color); }
        .gym-card[data-color="spin"] .progress-bar { background-color: var(--spin-color); }
        .gym-card[data-color="footwork"] { border-color: var(--footwork-color); }
        .gym-card[data-color="footwork"] .progress-bar { background-color: var(--footwork-color); }
        .gym-card[data-color="freeze"] { border-color: var(--freeze-color); }
        .gym-card[data-color="freeze"] .progress-bar { background-color: var(--freeze-color); }
        .gym-card[data-color="toprock"] { border-color: var(--toprock-color); }
        .gym-card[data-color="toprock"] .progress-bar { background-color: var(--toprock-color); }
        .gym-card[data-color="battle"] { border-color: var(--battle-color); }
        .gym-card[data-color="battle"] .progress-bar { background-color: var(--battle-color); }
        .gym-card[data-color="character"] { border-color: var(--character-color); }
        .gym-card[data-color="character"] .progress-bar { background-color: var(--character-color); }
        .gym-card[data-color="fusion"] { border-color: var(--fusion-color); }
        .gym-card[data-color="fusion"] .progress-bar { background-color: var(--fusion-color); }
        .gym-card[data-color="legacy"] { border-color: var(--legacy-color); }
        .gym-card[data-color="legacy"] .progress-bar { background-color: var(--legacy-color); }

        .back-link {
            display: inline-block;
            margin-bottom: 20px;
            color: var(--text-light);
            text-decoration: none;
            font-size: 0.9em;
            border: 1px solid #444;
            padding: 5px 15px;
            border-radius: 4px;
        }
        .back-link:hover { border-color: var(--power-color); }
    </style>
</head>
<body>

