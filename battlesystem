const GYMS_DATA = [
    { "name": "Power Gym", "color": "power", "requiredMoves": ["Coin Drop to Windmill", "Flare", "One-Handed Airflare", "Reverse Airflare", "Elbow Airflare", "Airflare", "Windmill (clean)", "Barrel Windmill"] },
    { "name": "Style Gym", "color": "style", "requiredMoves": ["Threads", "Freeze to Swipe", "Taisuke Criticals", "Derulo Rock", "Comboing", "Boyoing", "Power Circle", "Toprock Shuffle"] },
    { "name": "Spin Gym", "color": "spin", "requiredMoves": ["Body Rock", "Scissors", "UFO", "CCs", "Bicycle Pumps", "CC Floor Rock", "Zulu Spins"] },
    { "name": "Footwork Gym", "color": "footwork", "requiredMoves": ["8-Step", "6-Step", "4-Step", "12-Step", "3-Step", "5-Step", "7-Step", "10-Step"] },
    { "name": "Freeze Gym", "color": "freeze", "requiredMoves": ["Airbaby Spin", "Turtle Freeze", "Airbaby", "Headstand", "Baby Freeze", "Shoulder Freeze", "Elbow Freeze", "Chair Freeze"] },
    { "name": "Toprock Gym", "color": "toprock", "requiredMoves": ["Bronx Rock", "Indian Step", "Basic Toprock", "Brooklyn Rock", "Hip Twist", "Latin Rock", "4 Corners", "Toprock Combo"] },
    { "name": "Battle Gym", "color": "battle", "requiredMoves": ["Head Swipe", "Pretzel", "Kip-Up to Freeze", "Collapse to Backspin", "Crab Freeze", "Head Flip", "Headspring", "Head Swipe Combo"] },
    { "name": "Character Gym", "color": "character", "requiredMoves": ["Belly Swim", "Back CCs", "Side Step", "Baby Love", "Outlaw Spin", "Power Step Hop", "Bridge Kickover", "Crab Walk"] },
    { "name": "Fusion Gym", "color": "fusion", "requiredMoves": ["Airchair Spin", "Elbow Airchair", "Sidechair", "Tripod Windmill", "Invert (Ponk)", "Hanging Airbaby", "Lotus Airbaby", "Reverse Airbaby"] },
    { "name": "Legacy Gym", "color": "legacy", "requiredMoves": ["Airchair", "Swipe", "Handcuffed Windmill", "Headspin (continuous)", "Elbow Spin", "Kip-Up", "Chair Flare"] }
];

const STORAGE_KEY = 'floorFighterProgress';

// LOGIC
function calculateAndDisplayTotalExp() {
    const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
    let total = 0;
    const map = new Map(MOVES_DATA.map(m => [m.name, m.difficulty]));
    for (const move in saved) {
        if (saved[move]) total += map.get(move) || 0;
    }
    document.getElementById('exp-display').textContent = `Total Power Level: ${total.toFixed(1)} EXP`;
}

function renderMoveList() {
    const container = document.getElementById('move-list-container');
    const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
    MOVES_DATA.forEach((move, i) => {
        const item = document.createElement('div');
        item.className = 'move-item';
        item.innerHTML = `
            <div>
                <label class="move-name-label" for="m-${i}">${i + 1}. ${move.name}</label>
                <span class="move-exp">(${move.difficulty.toFixed(1)})</span>
            </div>
            <input type="checkbox" class="move-checkbox" id="m-${i}" ${saved[move.name] ? 'checked' : ''} data-name="${move.name}">
        `;
        item.querySelector('input').addEventListener('change', handleToggle);
        container.appendChild(item);
    });
}

function handleToggle(e) {
    const name = e.target.dataset.name;
    const checked = e.target.checked;
    const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
    if (checked) saved[name] = true; else delete saved[name];
    localStorage.setItem(STORAGE_KEY, JSON.stringify(saved));
    updateGymStatus();
    calculateAndDisplayTotalExp();
}

function updateGymStatus() {
    const container = document.getElementById('gym-status-container');
    container.innerHTML = '';
    const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
    GYMS_DATA.forEach(gym => {
        const completed = gym.requiredMoves.filter(m => saved[m]).length;
        const percent = Math.round((completed / gym.requiredMoves.length) * 100);
        const eligible = percent === 100;
        
        const card = document.createElement('div');
        card.className = 'gym-card';
        card.setAttribute('data-color', gym.color);
        card.innerHTML = `
            <div class="gym-header">
                <span class="gym-name">${gym.name}</span>
                <span class="gym-status ${eligible ? 'status-eligible' : 'status-locked'}">${eligible ? 'READY TO BATTLE' : 'LOCKED'}</span>
            </div>
            <div class="progress-bar-container"><div class="progress-bar" style="width: ${percent}%"></div></div>
            <p style="font-size: 0.8em; margin-top: 8px;">Sync: ${percent}% (${completed}/${gym.requiredMoves.length} moves)</p>
        `;
        container.appendChild(card);
    });
}

document.addEventListener('DOMContentLoaded', () => {
    renderMoveList();
    updateGymStatus();
    calculateAndDisplayTotalExp();
});
</script>
