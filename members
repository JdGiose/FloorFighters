<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Floor Fighter | Member Profile</title>
    <style>
        :root {
            --neon-red: #ff0000;
            --dark-bg: #0a0a0a;
            --card-bg: #151515;
            --accent-gold: #ffd700;
            --text-gray: #888;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: var(--dark-bg);
            color: #eee;
            margin: 0;
            padding: 0;
        }

        /* Navigation */
        nav {
            background: #000;
            border-bottom: 1px solid #222;
            padding: 15px 0;
        }

        .nav-container {
            max-width: 1000px;
            margin: 0 auto;
            display: flex;
            justify-content: center;
            gap: 30px;
        }

        .nav-link {
            color: var(--text-gray);
            text-decoration: none;
            text-transform: uppercase;
            font-size: 0.85rem;
            font-weight: bold;
            transition: 0.3s;
        }

        .nav-link:hover { color: var(--neon-red); }

        .container {
            max-width: 1000px;
            margin: 40px auto;
            padding: 0 20px;
        }

        /* Profile Header */
        .profile-header {
            display: grid;
            grid-template-columns: 200px 1fr;
            gap: 30px;
            background: var(--card-bg);
            padding: 30px;
            border-radius: 12px;
            border: 1px solid #333;
            align-items: center;
            margin-bottom: 30px;
        }

        .avatar-box {
            width: 200px;
            height: 200px;
            background: #222;
            border: 2px solid var(--neon-red);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .avatar-box img { width: 100%; height: 100%; object-fit: cover; }

        .profile-info h1 {
            margin: 0;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--accent-gold);
        }

        .rank-badge {
            display: inline-block;
            background: var(--neon-red);
            padding: 5px 15px;
            border-radius: 4px;
            font-weight: bold;
            font-size: 0.8rem;
            margin-top: 10px;
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: var(--card-bg);
            padding: 20px;
            border-radius: 8px;
            border: 1px solid #222;
            text-align: center;
        }

        .stat-value {
            display: block;
            font-size: 2rem;
            font-weight: bold;
            color: #fff;
        }

        .stat-label {
            color: var(--text-gray);
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 1px;
        }

        /* Medal Collection */
        .medals-section {
            background: var(--card-bg);
            padding: 30px;
            border-radius: 12px;
            border: 1px solid #333;
        }

        .medal-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
            gap: 15px;
            margin-top: 20px;
        }

        .medal-slot {
            width: 80px;
            height: 80px;
            background: #111;
            border: 2px dashed #333;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            filter: grayscale(1);
            opacity: 0.3;
        }

        .medal-slot.earned {
            filter: grayscale(0);
            opacity: 1;
            border: 2px solid var(--accent-gold);
            background: radial-gradient(circle, rgba(255,215,0,0.2) 0%, rgba(0,0,0,0) 70%);
            color: var(--accent-gold);
            font-weight: bold;
            font-size: 0.6rem;
            text-align: center;
        }

        .btn-update {
            display: inline-block;
            margin-top: 20px;
            padding: 10px 20px;
            background: transparent;
            border: 1px solid var(--neon-red);
            color: var(--neon-red);
            text-decoration: none;
            border-radius: 4px;
            font-weight: bold;
            font-size: 0.8rem;
            transition: 0.3s;
        }

        .btn-update:hover { background: var(--neon-red); color: #fff; }

    </style>
</head>
<body>

<nav>
    <div class="nav-container">
        <a href="index.html" class="nav-link">Home</a>
        <a href="battle-system.html" class="nav-link">Battle System</a>
        <a href="members.html" class="nav-link" style="color: var(--neon-red);">Members</a>
        <a href="gym-leaders.html" class="nav-link">Gym Leaders</a>
        <a href="gallery.html" class="nav-link">Gallery</a>
        <a href="contact.html" class="nav-link">Contact</a>
    </div>
</nav>

<div class="container">
    <div class="profile-header">
        <div class="avatar-box">
            <!-- User can upload a profile pic to their repo -->
            <img src="https://placeholder.com" alt="Dancer Avatar">
        </div>
        <div class="profile-info">
            <h1>B-Boy / B-Girl Alias</h1>
            <div class="rank-badge">NOVICE CHALLENGER</div>
            <p style="color: #888; margin-top: 15px;">Joined the Floor Fighter Tournament in 2024. Currently training for the first Gym Battle.</p>
            <a href="contact.html" class="btn-update">SUBMIT BATTLE EVIDENCE</a>
        </div>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <span class="stat-value" id="power-lv">0</span>
            <span class="stat-label">Power Level (EXP)</span>
        </div>
        <div class="stat-card">
            <span class="stat-value">0 / 10</span>
            <span class="stat-label">Gym Medals</span>
        </div>
        <div class="stat-card">
            <span class="stat-value">0%</span>
            <span class="stat-label">Moves Mastered</span>
        </div>
    </div>

    <div class="medals-section">
        <h2 style="margin-top:0; text-transform: uppercase; font-size: 1.2rem; color: var(--accent-gold);">Medal Collection</h2>
        <div class="medal-grid">
            <div class="medal-slot">Pwr</div>
            <div class="medal-slot">Stl</div>
            <div class="medal-slot">Spn</div>
            <div class="medal-slot">Ftw</div>
            <div class="medal-slot">Frz</div>
            <div class="medal-slot">Top</div>
            <div class="medal-slot">Btl</div>
            <div class="medal-slot">Chr</div>
            <div class="medal-slot">Fus</div>
            <div class="medal-slot">Leg</div>
        </div>
        <p style="font-size: 0.8rem; color: #555; margin-top: 20px;">*Medals appear here once your Battle Evidence is verified by a Gym Leader.</p>
    </div>
</div>

<script>
    // Sync Power Level from LocalStorage (from Battle System page)
    document.addEventListener('DOMContentLoaded', () => {
        const STORAGE_KEY = 'floorFighterProgress';
        const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
        
        // This is a simple count for now - you could map this to your 104 moves data
        let count = Object.keys(saved).length;
        document.getElementById('power-lv').innerText = count * 10; // Mock calculation
    });
</script>

</body>
</html>
