<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Floor Fighter | Gym Leader Archives</title>
    <style>
        :root {
            --power-color: #ff4136; --style-color: #b10dc9; --spin-color: #ffdc00;
            --footwork-color: #0074d9; --freeze-color: #2ecc40; --toprock-color: #ff851b;
            --bg-dark: #0a0a0a; --card-bg: #151515;
        }

        body { font-family: 'Segoe UI', sans-serif; background: var(--bg-dark); color: #eee; margin: 0; padding: 20px; }
        header { text-align: center; margin-bottom: 50px; border-bottom: 1px solid #333; padding-bottom: 20px; }
        
        .leader-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 40px; max-width: 1400px; margin: 0 auto; }

        /* Card Setup */
        .leader-card { background: var(--card-bg); border-radius: 15px; border: 1px solid #333; overflow: hidden; }

        /* Main Image */
        .main-display { width: 100%; height: 400px; background: #111; position: relative; }
        .main-display img { width: 100%; height: 100%; object-fit: cover; }

        /* Thumbnail Album Bar */
        .album-bar { 
            display: flex; 
            gap: 10px; 
            padding: 10px; 
            background: #222; 
            overflow-x: auto; 
            border-bottom: 1px solid #333;
        }
        .thumb { 
            width: 50px; height: 50px; border-radius: 4px; cursor: pointer; 
            opacity: 0.5; transition: 0.3s; object-fit: cover; border: 2px solid transparent;
        }
        .thumb:hover, .thumb.active { opacity: 1; border-color: #fff; }

        /* Info Area */
        .leader-info { padding: 20px; min-height: 120px; border-top: 5px solid #444; }
        .l-name { font-size: 1.4rem; font-weight: bold; text-transform: uppercase; display: block; margin-bottom: 5px; }
        .l-gym { font-size: 0.8rem; font-weight: bold; text-transform: uppercase; color: var(--power-color); }
        .l-desc { font-size: 0.9rem; color: #aaa; margin-top: 10px; line-height: 1.4; }

        .card-power .leader-info { border-color: var(--power-color); }
        .card-power .l-gym { color: var(--power-color); }
    </style>
</head>
<body>

<header>
    <h1>Gym Leader Archives</h1>
    <p>Select a thumbnail to view the Masters of each style.</p>
</header>

<div class="leader-grid">
    <!-- POWER GYM ALBUM -->
    <div class="leader-card card-power" id="gym-power">
        <div class="main-display">
            <img id="power-main" src="leaders/power1.jpg" alt="Current Leader">
        </div>
        
        <!-- Album Thumbnails -->
        <div class="album-bar">
            <img class="thumb active" src="leaders/power1.jpg" onclick="updateLeader('power', 'Ignition', 'Master of Airflares.', this)">
            <img class="thumb" src="leaders/power2.jpg" onclick="updateLeader('power', 'Voltage', 'High-speed headspins specialist.', this)">
            <img class="thumb" src="leaders/power3.jpg" onclick="updateLeader('power', 'Crush', 'Heavyweight power move expert.', this)">
            <!-- Add up to 10 here -->
        </div>

        <div class="leader-info">
            <span class="l-gym">Power Gym</span>
            <span class="l-name" id="power-name">Ignition</span>
            <p class="l-desc" id="power-desc">Master of high-flying Airflares and explosive power moves.</p>
        </div>
    </div>

    <!-- STYLE GYM ALBUM -->
    <div class="leader-card card-style" id="gym-style">
        <div class="main-display">
            <img id="style-main" src="leaders/style1.jpg" alt="Current Leader">
        </div>
        
        <div class="album-bar">
            <img class="thumb active" src="leaders/style1.jpg" onclick="updateLeader('style', 'Vibe', 'Intricate thread specialist.', this)">
            <img class="thumb" src="leaders/style2.jpg" onclick="updateLeader('style', 'Flow', 'Rhythmic footwork master.', this)">
        </div>

        <div class="leader-info">
            <span class="l-gym" style="color: var(--style-color);">Style Gym</span>
            <span class="l-name" id="style-name">Vibe</span>
            <p class="l-desc" id="style-desc">Elegance meets the floor. Specializes in high-concept rhythmic combos.</p>
        </div>
    </div>
</div>

<script>
    function updateLeader(gymId, name, desc, thumbElement) {
        // Update Image
        document.getElementById(gymId + '-main').src = thumbElement.src;
        // Update Text
        document.getElementById(gymId + '-name').innerText = name;
        document.getElementById(gymId + '-desc').innerText = desc;
        
        // Update Active Thumbnail State
        let thumbs = thumbElement.parentElement.getElementsByClassName('thumb');
        for (let t of thumbs) t.classList.remove('active');
        thumbElement.classList.add('active');
    }
</script>

</body>
</html>
